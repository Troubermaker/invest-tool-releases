"""
release.py 的私密 token，**不要**提交到 git。

如何启用 zip 自动上传到 Gitee Releases：

  1. 复制本文件为 release_secret.py（去掉 .example 后缀）
  2. 去 https://gitee.com/profile/personal_access_tokens 生成 Personal Access Token
     -  权限勾选: ✅ projects（创建/编辑 release 需要）
  3. 把 token 填到下面的 GITEE_TOKEN
  4. release.py --publish 之后会自动：
        - 创建 Gitee Release（tag = vX.Y.Z）
        - 上传 zip 作为附件
        - 你不再需要手动到网页操作

环境变量也可以（优先级更高）：set GITEE_TOKEN=xxxxx
"""

GITEE_TOKEN = "5709adea878950e9115c77816f081fbf"
