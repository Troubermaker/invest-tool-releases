# =====================================================================
# invest_tool 配置文件示例
#
# 使用方法：
#   1. 把这个文件复制为 .env（注意没有 .example 后缀）：
#        copy .env.example .env       (Windows CMD)
#        cp .env.example .env         (PowerShell / Mac / Linux)
#   2. 把下面的 your_xxx_here 替换成真实值
#   3. 重启 invest_tool 后端，配置自动加载
#
# 重要：
#   - .env 文件包含密钥，已加入 .gitignore，不会被提交到 git
#   - 真实 OS 环境变量优先级高于本文件（OS 已设的不会被覆盖）
#   - 不需要的配置可以注释掉（行首加 #）或留空
# =====================================================================

# ---------- AI 大模型（用于 AI 复盘对话功能，可选）----------
# 兼容 OpenAI 协议的任何服务（OpenAI / DeepSeek / 智谱 / Moonshot 等）
# AI_API_KEY=your_api_key_here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL_NAME=gpt-3.5-turbo
